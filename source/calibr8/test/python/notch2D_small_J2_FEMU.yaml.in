notch2D small J2 FEMU:

  problem:
    name: notch2D_small_J2_FEMU_inverse

  discretization:
    geom file: '@CMAKE_SOURCE_DIR@/test/mesh/notch2D/notch2D.dmg'
    mesh file: '@CMAKE_BINARY_DIR@/test/python/notch2D_small_J2_FEMU_synthetic/'
    assoc file: '@CMAKE_SOURCE_DIR@/test/mesh/notch2D/notch2D.txt'
    num steps: 4
    step size: 1.

  residuals:
    global residual:
      type: 'mechanics_plane_stress'
      nonlinear max iters: 30
      nonlinear absolute tol: 1.e-8
      nonlinear relative tol: 1.e-8
      print convergence: false
    local residual:
      type: 'small_hill_plane_stress'
      nonlinear max iters: 500
      nonlinear absolute tol: 1.e-12
      nonlinear relative tol: 1.e-12
      # plasticity parameters start perturbed from truth (Y=2, S=10, D=2);
      # E, nu, and the Hill coefficients are held fixed at truth
      materials:
        body:
          E: 1000.
          nu: 0.25
          Y: 2.6
          S: 7.
          D: 3.
          R00: 1.
          R11: 1.
          R22: 1.
          R01: 1.

  dirichlet bcs:
    expression:
      bc 1: [0, 0, xmin, 0.0]
      bc 2: [0, 1, ymin, 0.0]
      bc 3: [0, 1, ymax, 0.003 * t]

  # calibration objective: full-field displacement mismatch + axial-load mismatch
  quantity of interest:
    type: 'calibration'
    balance factor: 4.22
    coordinate index: 1
    coordinate value: 1.0
    coordinate tolerance: 1.0e-6
    reaction force component: 1
    displacement weights: [3.98e+07, 3.98e+07]
    load input file: '@CMAKE_BINARY_DIR@/test/python/load.dat'
    objective out file: 'objective_at_step.txt'

  inverse:
    objective type: "pdeco"
    iteration limit: 150
    gradient tolerance: 1.0e-8
    barrier tolerance: 1.0e-8
    max line search evals: 20
    materials:
      body:
        Y: [1., 3.]
        S: [5., 15.]
        D: [1., 4.]

  linear algebra:
    Linear Solver Type: "Belos"
    Preconditioner Type: "Teko"
    Linear Solver Types:
      Belos:
        Solver Type: "Block GMRES"
        Solver Types:
          Block GMRES:
            Convergence Tolerance: 1.e-6
            Output Frequency: 10
            Output Style: 1
            Verbosity: 33
            Maximum Iterations: 200
            Block Size: 1
            Num Blocks: 200
            Flexibile Gmres: false
        VerboseObject:
          Output File: "none"
          Verbosity Level: "none"
    Preconditioner Types:
      Teko:
        Inverse Type: "BGS2x2"
        Write Block Operator: false
        Test Block Operator: false
        Inverse Factory Library:
          BGS2x2:
            Type: "Block Gauss-Seidel"
            Use Upper Triangle: false
            Inverse Type 1: "AMG2"
          AMG2:
            Type: "MueLu"
            number of equations: 2
            verbosity: "none"
            'problem: symmetric': false
          GS:
            Type: "Ifpack2"
            Overlap: 1
            Ifpack2 Settings:
              'relaxation: type': "Gauss-Seidel"
